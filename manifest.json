{
  "manifest_version": 3,
  "name": "GitStandup",
  "version": "2.0.0",
  "description": "Generate polished standup drafts from your GitHub commits, PRs, and extra context.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.github.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "GitStandup",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}